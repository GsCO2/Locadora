	<parameter name="idLocacao" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT car.placa, car.marca, car.modelo, car.cor, car.ano, loc.nome, SUBSTRING(loc.cpf, 1, 3) + '.' +
    SUBSTRING(loc.cpf, 4, 3) + '.' +
    SUBSTRING(loc.cpf, 7, 3) + '-' +
    SUBSTRING(loc.cpf, 10, 2) AS cpf, alg.qtd_dias
FROM carro car, locatario loc, aluguel alg
WHERE car.placa = alg.placa_carro
AND alg.cpf_locatario = loc.cpf
AND alg.id = $P{idLocacao}]]></query>
